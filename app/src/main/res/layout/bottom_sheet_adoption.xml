<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_rounded_surface"
    android:padding="24dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="@color/divider"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/adoption_agreement"
        android:textSize="20sp"
        android:textColor="@color/text_primary"
        android:fontFamily="@font/poppins"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:fontFamily="@font/poppins"
        android:visibility="gone"
        android:layout_marginBottom="16dp" />

    <ScrollView
        android:id="@+id/scrollViewAgreement"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_input_rounded"
        android:padding="20dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="20dp">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OFFICIAL ADOPTION COVENANT"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:fontFamily="@font/poppins"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp" />
                
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1. Guardianship &amp; Care Standards"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:fontFamily="@font/poppins"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="The adopter agrees to assume full legal and physical responsibility for the care, nutrition, and medical needs of the animal, maintaining standard health vaccinations."
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontFamily="@font/poppins"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="16dp" />
                
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2. Home Inspections &amp; Access"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:fontFamily="@font/poppins"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PawHome reserves the right to conduct scheduled check-ins of the living environment to ensure safety, emotional security, and welfare of the pet."
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontFamily="@font/poppins"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="16dp" />
                
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3. Reclamation Rights"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:fontFamily="@font/poppins"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="In the event of negligence, abandonment, or failure to uphold care standards, PawHome maintains immediate legal rights to reclaim custody without reimbursement."
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontFamily="@font/poppins"
                android:lineSpacingExtra="3dp" />
                
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/layoutAgreementButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDecline"
            style="@style/Widget.PawHome.Button.Secondary"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="52dp"
            android:text="@string/decline"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="12dp"
            android:layout_marginEnd="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAccept"
            style="@style/Widget.PawHome.Button.Primary"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="52dp"
            android:text="@string/accept"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="12dp"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutSignature"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginTop="8dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:text="@string/sign_here"
                android:textColor="@color/text_primary"
                android:fontFamily="@font/poppins"
                android:textStyle="bold" />
                
            <TextView
                android:id="@+id/btnClear"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="@string/clear_signature"
                android:textColor="@color/primary"
                android:textSize="14sp"
                android:fontFamily="@font/poppins"
                android:textStyle="bold"
                android:padding="4dp" />
        </RelativeLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:background="@drawable/bg_signature_pad"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_draw"
                app:tint="@color/divider" />

            <com.example.midtermproject.ui.detail.SignatureView
                android:id="@+id/signatureView"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSignatureBack"
                style="@style/Widget.PawHome.Button.Secondary"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="52dp"
                android:text="Back"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="12dp"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubmit"
                style="@style/Widget.PawHome.Button.Primary"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="52dp"
                android:text="@string/confirm"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="12dp"
                android:layout_marginStart="8dp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
