<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ==================== Card Styles ==================== -->
    <style name="Widget.PawHome.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/card_background</item>
        <item name="contentPadding">0dp</item>
    </style>

    <style name="Widget.PawHome.Card.Flat" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">@color/surface_variant</item>
    </style>

    <!-- ==================== Button Styles ==================== -->
    <style name="Widget.PawHome.Button.Primary" parent="Widget.Material3.Button">
        <item name="cornerRadius">16dp</item>
        <item name="android:textSize">16sp</item>
        <item name="backgroundTint">@color/primary</item>
    </style>

    <style name="Widget.PawHome.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textSize">16sp</item>
        <item name="strokeColor">@color/primary</item>
        <item name="android:textColor">@color/primary</item>
    </style>

    <style name="Widget.PawHome.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/primary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="Widget.PawHome.Button.Success" parent="Widget.Material3.Button">
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="backgroundTint">@color/success</item>
    </style>

    <style name="Widget.PawHome.Button.Danger" parent="Widget.Material3.Button">
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="backgroundTint">@color/error</item>
    </style>

    <!-- ==================== TextInput Styles ==================== -->
    <style name="Widget.PawHome.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeColor">@color/primary</item>
        <item name="hintTextColor">@color/primary</item>
    </style>

    <!-- ==================== Text Styles ==================== -->
    <style name="TextAppearance.PawHome.Headline" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.PawHome.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.PawHome.Subtitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.PawHome.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.PawHome.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- ==================== Chip Styles ==================== -->
    <style name="Widget.PawHome.Chip" parent="Widget.Material3.Chip.Filter">
        <item name="chipCornerRadius">20dp</item>
        <item name="chipBackgroundColor">@color/surface_variant</item>
        <item name="checkedIconVisible">false</item>
    </style>

    <!-- ==================== Bottom Navigation ==================== -->
    <style name="Widget.PawHome.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@android:color/transparent</item>
        <item name="itemIconTint">@color/nav_item_color_state</item>
        <item name="itemTextColor">@color/nav_item_color_state</item>
        <item name="itemRippleColor">@null</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.PawHome.BottomNavigation.ActiveIndicator</item>
    </style>

    <style name="Widget.PawHome.BottomNavigation.ActiveIndicator" parent="">
        <item name="android:color">@android:color/transparent</item>
    </style>

    <!-- ==================== Status Badge ==================== -->
    <style name="Widget.PawHome.StatusBadge" parent="">
        <item name="android:background">@color/status_available</item>
        <item name="android:textColor">@color/on_success</item>
        <item name="android:textSize">12sp</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
        <item name="android:paddingTop">3dp</item>
        <item name="android:paddingBottom">3dp</item>
    </style>

    <!-- ==================== Tab Text ==================== -->
    <style name="TextAppearance.PawHome.TabText" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textSize">14sp</item>
    </style>

    <!-- ==================== Custom Shapes ==================== -->
    <style name="ShapeAppearance.PawHome.Card.TopRounded" parent="">
        <item name="cornerSizeTopLeft">32dp</item>
        <item name="cornerSizeTopRight">32dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>
</resources>
